{
  "version": 2,
  "builds": [
    {
      "src": "backend/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/ml-sync",
      "dest": "/backend/ml-sync.js"
    },
    {
      "src": "/api/ml-token",
      "dest": "/backend/ml-token.js"
    }
  ]
}
