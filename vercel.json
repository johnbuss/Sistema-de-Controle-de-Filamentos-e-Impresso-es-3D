{
  "version": 2,
  "builds": [
    {
      "src": "backend/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ml-callback",
      "dest": "/backend/ml-callback.js",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/api/ml-sync",
      "dest": "/backend/ml-sync.js",
      "methods": ["GET", "POST", "OPTIONS"]
    },
    {
      "src": "/api/ml-token",
      "dest": "/backend/ml-token.js",
      "methods": ["GET", "POST", "OPTIONS"]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "backend/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
